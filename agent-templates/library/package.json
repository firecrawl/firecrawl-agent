{
  "name": "my-firecrawl-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --import tsx/esm index.ts",
    "dev": "node --import tsx/esm --watch index.ts",
    "example:basic": "node --import tsx/esm examples/1-basic.ts",
    "example:structured": "node --import tsx/esm examples/2-structured-output.ts",
    "example:parallel": "node --import tsx/esm examples/3-parallel-subagents.ts",
    "example:skills": "node --import tsx/esm examples/4-with-skills.ts",
    "example:stream": "node --import tsx/esm examples/5-streaming.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "latest",
    "@ai-sdk/google": "latest",
    "@ai-sdk/openai": "latest",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.3.3"
  }
}
